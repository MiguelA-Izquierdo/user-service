# For local development (without Docker): copy to .env
# For Docker Compose: copy to .env.docker and run:
#   docker compose --env-file .env.docker up

# Database (full JDBC URL)
DB_URL=jdbc:mysql://localhost:3306/user_service_db
DB_USER=appuser
DB_PASSWORD=apppassword

# JWT — must be at least 32 characters
JWT_SECRET=your-secret-key-change-in-production-min32chars
# Token lifetime in milliseconds (optional, default 86400000 = 24h)
# JWT_EXPIRATION=86400000

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# CORS (optional, defaults to http://localhost:4200)
# CORS_ALLOWED_ORIGINS=http://localhost:3000

# Logging levels (default INFO; use DEBUG only for local/dev — never in production)
# LOG_LEVEL_APP=INFO
# LOG_LEVEL_MESSAGING=INFO

# Base URL for pagination links (set to the public-facing URL in production)
APP_BASE_URL=http://localhost:8080

# Admin seed user (created on first startup if it does not exist)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin1234!@Secure
ADMIN_NAME=Admin
ADMIN_LAST_NAME=Admin

# Security (optional)
# Enable HTTP Strict-Transport-Security header (only behind HTTPS; default false)
# SECURITY_HSTS_ENABLED=false

# Actuator management port (optional, default 8081)
# MANAGEMENT_PORT=8081

# Rate limiting (optional) — see docs/deployment.md
# Backend: memory or redis (default memory)
# RATE_LIMIT_BACKEND=memory
# Trust X-Forwarded-For for client IP — enable only behind a trusted proxy (default false)
# RATE_LIMIT_TRUST_PROXY=false
# Let the Redis health indicator affect /actuator/health — keep false unless Redis is the active backend (default false)
# RATE_LIMIT_REDIS_HEALTH=false

# Redis (optional, required when RATE_LIMIT_BACKEND=redis)
# REDIS_HOST=localhost
# REDIS_PORT=6379