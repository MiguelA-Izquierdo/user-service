# For local development (without Docker): copy to .env
# For Docker Compose: copy to .env.docker and run:
#   docker compose --env-file .env.docker up

# Database (full JDBC URL)
DB_URL=jdbc:mysql://localhost:3306/user_service_db
DB_USER=appuser
DB_PASSWORD=apppassword

# JWT — must be at least 32 characters
JWT_SECRET=your-secret-key-change-in-production-min32chars

# RabbitMQ
RABBITMQ_USER_SERVICE_HOST=localhost
RABBITMQ_USER_SERVICE_PORT=5672
RABBITMQ_USER_SERVICE_USER_NAME=guest
RABBITMQ_USER_SERVICE_PASSWORD=guest

# CORS (optional, defaults to http://localhost:4200)
# CORS_ALLOWED_ORIGINS=http://localhost:3000

# Base URL for pagination links (set to the public-facing URL in production)
APP_BASE_URL=http://localhost:8080

# Admin seed user (created on first startup if it does not exist)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin1234!
ADMIN_NAME=Admin
ADMIN_LAST_NAME=Admin